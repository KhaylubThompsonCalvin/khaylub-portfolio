# .env.example — documents the ENV VARIABLE NAMES this project uses.
# Copy to `.env` (gitignored) and fill values locally. NAMES ONLY here — never real values.
#
# Scope rules (see CLAUDE.md → AI Tooling Guardrails → MCP / API key handling):
#   - MCP keys (21st.dev, etc.) live in LOCAL MCP config, NOT in this file.
#   - CodeRabbit + CI credentials live in GitHub repository secrets, NOT in this file.
#   - Vite exposes ONLY variables prefixed VITE_ to client code.

# Canonical site origin — used for absolute SEO / OpenGraph URLs (e.g. https://khaylub.com)
VITE_SITE_URL=

# Optional — contact form submission endpoint, if the mailto: link is later replaced by a form.
# VITE_CONTACT_ENDPOINT=
